{
    "name": "mafaza-api",
    "version": "1.0.0",
    "description": "Mafaza — investment tracking API",
    "license": "MIT",
    "private": true,
    "scripts": {
        "start": "node ./server.js",
        "start:dev": "nodemon ./server.js",
        "create-admin": "node ./scripts/create-admin.js",
        "db:create": "npx sequelize-cli db:create",
        "db:migrate": "npx sequelize-cli db:migrate",
        "db:migrate:fresh": "npx sequelize-cli db:migrate:undo && npx sequelize-cli db:migrate",
        "db:seed": "npx sequelize-cli db:seed:all",
        "db:reset": "npx sequelize-cli db:drop && npx sequelize-cli db:create && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
    },
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "body-parser": "^1.19.0",
        "cookie-parser": "^1.4.5",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.17.1",
        "express-handlebars": "^7.1.2",
        "express-jwt": "^6.0.0",
        "express-rate-limit": "^7.5.1",
        "fs": "^0.0.1-security",
        "helmet": "^8.1.0",
        "joi": "^17.2.1",
        "jsonwebtoken": "^8.5.1",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.4.11",
        "nodemailer-express-handlebars": "^6.1.0",
        "pg": "^8.13.1",
        "pg-hstore": "^2.3.4",
        "rootpath": "^0.1.2",
        "sequelize": "^6.35.2",
        "sequelize-cli": "^6.6.2",
        "swagger-ui-express": "^4.1.4",
        "uuid": "^11.1.1",
        "yamljs": "^0.3.0"
    },
    "devDependencies": {
        "nodemon": "^2.0.3"
    }
}
