APP_NAME=Mafaza
# Railway injects PORT; APP_PORT is an optional override
APP_PORT=8000
NODE_ENV=development
# Required in production: public HTTPS origin of this app (used for CORS + emails), e.g. https://your-app.up.railway.app
APP_URL=http://localhost:3000

# Optional: extra allowed browser origins (comma-separated). Defaults to APP_URL origin when unset.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Security (production): set HELMET_CSP=false only if Content-Security-Policy breaks a feature (then fix CSP instead).
# HELMET_CSP=false
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=400
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=30

# Use Railway Postgres "DATABASE_URL" in production, or set discrete variables locally:
# DATABASE_URL=postgres://...
DATABASE_SSL=
# PGSSLMODE=disable

DB_CONNECTION=postgres
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=senisha
DB_USERNAME=postgres
DB_PASSWORD=postgres
# DB_SSL=true

MAIL_HOST=smtp.google.com
MAIL_PORT=587
MAIL_USERNAME=infocliq
MAIL_PASSWORD=""
MAIL_FROM_ADDRESS=infocliq@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Required — signing JWTs. Railway: add this variable to your web service. Example: openssl rand -hex 32
JWT_SECRET_KEY=

ZEPTOMAIL_API_URL=
ZEPTOMAIL_API_KEY=
ZEPTOMAIL_FROM_EMAIL=
ZEPTOMAIL_FROM_NAME=
MIGRATION_LOGIN_URL=http://localhost:3001/login
PASSWORD_RESET_URL=http://localhost:3001/reset-password
